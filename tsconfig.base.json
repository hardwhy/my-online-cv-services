{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@web-cv-services/shared-types": ["packages/shared-types/src/index.ts"],
      "@web-cv-services/shared-services": ["packages/shared-services/src/index.ts"],
      "@web-cv-services/cv-renderer": ["packages/cv-renderer/src/index.ts"]
    }
  }
}
